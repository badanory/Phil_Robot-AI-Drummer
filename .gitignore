# --- [1] 빌드 및 컴파일 산출물 (전체 적용) ---
*.o
*.out
*.so
*.a
txt*.md
AGENTS.md

# --- [2] DrumRobot2: 빈 폴더 구조 유지 ---
# obj 폴더 비우기 (단, .gitkeep은 제외)
DrumRobot2/obj/*
!DrumRobot2/obj/.gitkeep

# bin 폴더 비우기 (단, .gitkeep은 제외)
DrumRobot2/bin/*
!DrumRobot2/bin/.gitkeep

# DrumRobot_data 비우기 (데이터 파일 무시, .gitkeep은 유지)
DrumRobot_data/*
!DrumRobot_data/.gitkeep

# --- [3] Python/Magenta/phil_robot 관련 ---
# 가상환경 및 캐시 (이름이 뭐든 간에 venv, env 들어가면 무시)
venv/
env/
*.env
magenta-env/
__pycache__/
*.pyc
.ipynb_checkpoints/

# 휠 파일 등 대용량 설치 파일 제외
phil_robot/downloads_whl/
phil_robot/third_party/downloads_whl/

# legacy mock/simulator workspace (already tracked files remain tracked)
phil_intheloop/


# --- [4] IDE 설정 및 시스템 파일 ---
.idea/
.DS_Store
Thumbs.db
ppt/

# --- [5]  phil_robot 생성 미디어 파일 ---
# 어디에 있든 이 확장자는 다 무시함
phil_robot/*.wav
phil_robot/*.mp3
phil_robot/artifacts/
phil_robot/**/__pycache__/
**/*.log
